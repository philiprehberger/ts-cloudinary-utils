{
  "name": "@philiprehberger/cloudinary-utils",
  "version": "0.2.4",
  "description": "Cloudinary image URL builder, srcset generation, and blur placeholders",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test src/__tests__/index.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "cloudinary",
    "image",
    "optimization",
    "srcset",
    "blur",
    "placeholder",
    "next.js"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-cloudinary-utils.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-cloudinary-utils#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-cloudinary-utils/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
