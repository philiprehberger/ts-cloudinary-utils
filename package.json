{
  "name": "@philiprehberger/cloudinary-utils",
  "version": "0.2.10",
  "description": "Cloudinary image URL builder, srcset generation, and blur placeholders",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1"
  },
  "keywords": [
    "cloudinary",
    "image",
    "optimization",
    "srcset",
    "blur",
    "placeholder",
    "next.js"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-cloudinary-utils.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-cloudinary-utils#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-cloudinary-utils/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
